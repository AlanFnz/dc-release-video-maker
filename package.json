{
  "name": "dc-release-video-maker",
  "version": "0.1.0",
  "description": "Generate vinyl-style release videos for Dub Culture",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && node scripts/fetch-ffmpeg-x64.mjs && electron-builder",
    "package:win": "electron-vite build && node scripts/fetch-ffmpeg-win.mjs && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.nebula.dc-release-video-maker",
    "productName": "DC Release Video Maker",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "mac": {
      "target": {
        "target": "dmg",
        "arch": ["universal"]
      },
      "category": "public.app-category.music",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": "zip",
      "extraResources": [
        {
          "from": "node_modules/ffmpeg-static/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    }
  }
}
